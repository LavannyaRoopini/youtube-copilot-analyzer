# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4

# YouTube Configuration (optional)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./videos.db

# Server Configuration
